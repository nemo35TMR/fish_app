<div id="<%= dom_id(message) %>" class="message-row">

  <% if message.role == "user" %>
    <div class="message message-user">
      <div class="message-content">
        <%= simple_format(message.content) %>
      </div>
    </div>
  <% else %>
    <div class="message message-ai">
      <div class="message-content">
        <%= simple_format(message.content) %>
      </div>
    </div>
  <% end %>

</div>
