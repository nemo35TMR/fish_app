<% content_for :title, "Carte des lacs — Canada" %>
<% content_for :head do %>
  <meta name="turbo-visit-control" content="reload">
  <link rel="stylesheet" href="/leaflet/leaflet.css" data-turbo-track="reload">
<% end %>

<div
  class="lakes-map-page"
  data-controller="lakes-map"
  data-lakes-map-geocoding-url-value="<%= geocoding_search_path %>"
  <%# URL du JSON des lacs (même requête ActiveRecord que la page HTML, voir LakesController#index). %>
  data-lakes-map-lakes-json-url-value="<%= lakes_path(format: :json) %>"
  data-lakes-map-chat-url-format-value="<%= lake_chat_new_path_template %>"
>
  <header class="lakes-map-page__toolbar shadow-sm">
    <div class="container-fluid py-2 py-md-3">
      <form class="row g-2 align-items-end" data-action="submit->lakes-map#searchAddress">
        <div class="col-12 col-md-5 col-lg-4">
          <label class="form-label small text-muted mb-1">Ville ou lieu (Canada)</label>
          <input
            type="search"
            class="form-control"
            placeholder="Ex. Montréal, Québec, Saguenay, Lac-Saint-Jean…"
            autocomplete="off"
            data-lakes-map-target="searchInput"
          />
        </div>
        <div class="col-6 col-md-2 col-lg-2">
          <label class="form-label small text-muted mb-1">Rayon</label>
          <select class="form-select" data-lakes-map-target="radiusSelect" data-action="change->lakes-map#radiusChanged">
            <% [25, 50, 75, 100, 150].each do |km| %>
              <option value="<%= km %>" <%= "selected" if km == 75 %>><%= km %> km</option>
            <% end %>
          </select>
        </div>
        <div class="col-6 col-md-5 col-lg-4 d-flex flex-wrap gap-2 align-items-end">
          <button type="submit" class="btn btn-primary flex-grow-1">Rechercher</button>
          <button type="button" class="btn btn-outline-secondary flex-grow-1" data-action="click->lakes-map#useMyLocation">Ma position</button>
          <button type="button" class="btn btn-outline-dark flex-grow-1" data-action="click->lakes-map#clearSearch">Réinitialiser</button>
        </div>
      </form>
      <div class="small text-danger mt-2 d-none" data-lakes-map-target="errorBox"></div>
    </div>
  </header>

  <div class="lakes-map-page__layout">
    <section class="lakes-map-page__map" aria-label="Carte interactive">
      <div class="lakes-map-page__map-inner" data-lakes-map-target="mapContainer"></div>
    </section>

    <aside class="lakes-map-page__panel">
      <div class="card border-0 shadow-sm h-100 lakes-map-page__panel-card">
        <div class="card-body d-flex flex-column gap-3 min-h-0">
          <section class="lake-results flex-shrink-0">
            <div class="d-flex justify-content-between align-items-baseline mb-2">
              <h2 class="h6 text-uppercase text-muted mb-0">Lacs dans la zone</h2>
              <span class="badge text-bg-primary rounded-pill" data-lakes-map-target="resultsCount">0</span>
            </div>
            <p class="small text-muted d-none mb-2" data-lakes-map-target="resultsEmpty">Aucun lac dans ce rayon — élargissez la distance ou déplacez la recherche.</p>
            <ul class="list-group list-group-flush border rounded lake-results__scroll" data-lakes-map-target="resultsList"></ul>
          </section>

          <hr class="my-0 flex-shrink-0">

          <div class="flex-grow-1 d-flex flex-column min-h-0">
            <div data-lakes-map-target="emptyState" class="text-muted small lakes-map-page__fade">
              <p class="mb-2 fw-semibold text-body">Détails du lac</p>
              <p class="mb-0">Recherchez une ville ou utilisez votre position, puis sélectionnez un lac dans la liste ou sur la carte.</p>
            </div>

            <div data-lakes-map-target="details" class="d-none lakes-map-page__fade flex-grow-1 d-flex flex-column min-h-0">
              <div class="d-flex justify-content-between align-items-start gap-2">
                <h3 class="h5 mb-1 d-flex align-items-center gap-2 lake-panel__title">
                  <span class="lake-panel__title-icon" aria-hidden="true">🌊</span>
                  <span data-lakes-map-target="lakeName"></span>
                </h3>
              </div>
              <p class="small text-muted mb-2 d-flex align-items-start gap-2 lake-panel__meta">
                <span class="lake-panel__meta-icon" aria-hidden="true">📍</span>
                <span data-lakes-map-target="lakeLocation"></span>
              </p>
              <div class="d-flex gap-2 align-items-start mb-0 lake-panel__desc">
                <span class="lake-panel__desc-icon flex-shrink-0" aria-hidden="true">📄</span>
                <p class="mb-0 small flex-grow-1" data-lakes-map-target="lakeDescription"></p>
              </div>

              <hr class="my-3">

              <section>
                <h4 class="lake-panel__section-title">
                  <span class="lake-panel__section-title-icon" aria-hidden="true">🐟</span>
                  <span>Poissons</span>
                </h4>
                <div class="lake-panel__fish-grid" data-lakes-map-target="fishList"></div>
              </section>

              <section class="mt-3 flex-grow-1 d-flex flex-column min-h-0">
                <h4 class="lake-panel__section-title">
                  <span class="lake-panel__section-title-icon" aria-hidden="true">🎣</span>
                  <span>Leurres par espèce</span>
                </h4>
                <ul class="list-group list-group-flush border rounded small flex-grow-1 overflow-auto lake-panel__lures-list" data-lakes-map-target="luresList"></ul>
              </section>

              <div class="mt-3 pt-1 flex-shrink-0">
                <% if Current.user %>
                  <%= link_to "Ouvrir un chat sur ce lac", "#", class: "btn btn-outline-primary btn-sm w-100", data: { lakes_map_target: "chatLink" } %>
                <% else %>
                  <%= link_to "Connectez-vous pour chatter sur ce lac", new_user_session_path, class: "btn btn-outline-secondary btn-sm w-100" %>
                <% end %>
              </div>
            </div>
          </div>
        </div>
      </div>
    </aside>
  </div>
</div>
