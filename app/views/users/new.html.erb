<% content_for :title, "Inscription" %>
<div class="container py-5" style="max-width: 420px">
  <h1 class="h4 mb-4">Créer un compte</h1>
  <%= form_with model: @user, class: "card shadow-sm border-0" do |f| %>
    <div class="card-body d-grid gap-3">
      <% if @user.errors.any? %>
        <div class="alert alert-danger small mb-0">
          <%= @user.errors.full_messages.to_sentence %>
        </div>
      <% end %>
      <div>
        <%= f.label :email, "Email", class: "form-label" %>
        <%= f.email_field :email, class: "form-control", required: true, autocomplete: "username" %>
      </div>
      <div>
        <%= f.label :password, "Mot de passe (8 caractères min.)", class: "form-label" %>
        <%= f.password_field :password, class: "form-control", required: true, autocomplete: "new-password" %>
      </div>
      <div>
        <%= f.label :password_confirmation, "Confirmation", class: "form-label" %>
        <%= f.password_field :password_confirmation, class: "form-control", required: true, autocomplete: "new-password" %>
      </div>
      <%= f.submit "S’inscrire", class: "btn btn-primary" %>
    </div>
  <% end %>
  <p class="small text-muted mt-3 mb-0">
    Déjà inscrit ? <%= link_to "Se connecter", new_session_path %>
  </p>
</div>
