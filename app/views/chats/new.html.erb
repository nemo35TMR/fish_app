<% content_for :title, "Nouveau chat" %>
<div class="container py-4" style="max-width: 520px">
  <h1 class="h4 mb-3">Nouvelle conversation</h1>
  <p class="text-muted small">Lac : <strong><%= @lake.name %></strong></p>

  <%= form_with model: [@lake, @chat], class: "card shadow-sm border-0" do |f| %>
    <div class="card-body d-grid gap-3">
      <% if @chat.errors.any? %>
        <div class="alert alert-danger small mb-0">
          <%= @chat.errors.full_messages.to_sentence %>
        </div>
      <% end %>
      <div>
        <%= f.label :title, "Titre", class: "form-label" %>
        <%= f.text_field :title, class: "form-control", required: true, placeholder: "Ex. conditions du jour, montage…" %>
      </div>
      <div class="form-check">
        <%= f.check_box :favorite, class: "form-check-input" %>
        <%= f.label :favorite, "Marquer comme favori", class: "form-check-label" %>
      </div>
      <%= f.submit "Créer le chat", class: "btn btn-primary" %>
    </div>
  <% end %>
  <%= link_to "Annuler", root_path, class: "btn btn-link px-0 mt-2" %>
</div>
