<div class="container py-4" style="max-width: 820px">

  <div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h4 mb-0">Mes conversations</h1>
    <%= link_to "Carte des lacs", root_path, class: "btn btn-outline-secondary btn-sm" %>
  </div>

  <% if @chats.any? %>

    <div class="list-group shadow-sm rounded overflow-hidden">

      <% @chats.each do |chat| %>

        <div class="list-group-item d-flex justify-content-between align-items-center py-3">

          <!-- Infos -->
          <div>
            <div class="fw-semibold mb-1">
              <%= chat.title.presence || "Conversation" %>
            </div>
            <div class="small text-muted">
              <%= chat.lake.name %> • <%= chat.created_at.strftime("%d %b %Y") %>
            </div>
          </div>

          <!-- Actions -->
          <div class="d-flex align-items-center gap-2">

            <%= link_to chat_path(chat),
                class: "btn btn-sm btn-outline-primary px-3" do %>
              Ouvrir
            <% end %>

            <%= button_to chat_path(chat),
                method: :delete,
                data: { turbo_confirm: "Supprimer cette conversation ?" },
                class: "btn btn-sm btn-outline-danger px-3" do %>
              Supprimer
            <% end %>

          </div>

        </div>

      <% end %>

    </div>

  <% else %>

    <div class="text-center py-5">
      <p class="text-muted mb-3">Aucune conversation pour le moment.</p>
      <%= link_to "Explorer les lacs", root_path, class: "btn btn-primary" %>
    </div>

  <% end %>

</div>
