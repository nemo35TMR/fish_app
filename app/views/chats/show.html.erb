<div class="container py-4" style="max-width: 760px">

  <!-- HEADER -->
  <div class="d-flex justify-content-between align-items-start mb-4">

    <div>
      <h1 class="h5 mb-1"><%= @chat.title %></h1>
      <small class="text-muted">
        <%= @chat.lake.name %>
      </small>
    </div>

    <div class="d-flex flex-column align-items-end gap-2">

      <%= link_to "Retour",
          chats_path,
          class: "btn btn-outline-secondary btn-sm" %>

      <%= link_to "Supprimer",
          chat_path(@chat),
          data: {
            turbo_method: :delete,
            turbo_confirm: "Supprimer cette conversation ?"
          },
          class: "btn btn-outline-danger btn-sm" %>

    </div>

  </div>

  <!-- TURBO STREAM -->
  <%= turbo_stream_from @chat %>

  <!-- MESSAGES -->
  <div id="messages"
       class="chat-container mb-3"
       data-controller="chat-scroll">

    <% @chat.messages.each do |message| %>
      <%= render "messages/message", message: message %>
    <% end %>

  </div>

  <!-- FORM -->
  <div id="new_message_container" class="chat-form">
    <%= render "messages/form", chat: @chat, message: Message.new %>
  </div>

</div>
