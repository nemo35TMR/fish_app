<% content_for :title, "Connexion" %>
<div class="container py-5" style="max-width: 420px">
  <h1 class="h4 mb-4">Connexion</h1>
  <%= form_with url: session_path, class: "card shadow-sm border-0" do |f| %>
    <div class="card-body d-grid gap-3">
      <div>
        <%= label_tag :email, "Email", class: "form-label" %>
        <%= email_field_tag :email, params[:email], class: "form-control", required: true, autocomplete: "username" %>
      </div>
      <div>
        <%= label_tag :password, "Mot de passe", class: "form-label" %>
        <%= password_field_tag :password, nil, class: "form-control", required: true, autocomplete: "current-password" %>
      </div>
      <%= submit_tag "Se connecter", class: "btn btn-primary" %>
    </div>
  <% end %>
  <p class="small text-muted mt-3 mb-0">
    Pas encore de compte ? <%= link_to "Créer un compte", new_user_path %>
  </p>
</div>
